{
    "name": "iobroker.alarm",
    "version": "4.0.2",
    "description": "Your own lttle alarm system",
    "author": {
        "name": "misanorot",
        "email": "audi16v@gmx.de"
    },
    "homepage": "https://github.com/misanorot/ioBroker.alarm",
    "license": "MIT",
    "keywords": [
        "alarm system",
        "security",
        "protection",
        "ioBroker"
    ],
    "repository": {
        "type": "git",
        "url": "git@github.com:misanorot/ioBroker.alarm.git"
    },
    "engines": {
        "node": ">= 20"
    },
    "dependencies": {
        "@iobroker/adapter-core": "^3.3.2",
        "node-schedule": "^2.1.1",
        "suncalc2": "^1.8.1"
    },
    "devDependencies": {
        "@alcalzone/release-script": "^5.1.1",
        "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
        "@alcalzone/release-script-plugin-license": "^5.1.1",
        "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
        "@iobroker/adapter-dev": "^1.5.0",
        "@iobroker/eslint-config": "^2.2.0",
        "@iobroker/testing": "^5.2.2",
        "@iobroker/types": "^7.1.1",
        "@tsconfig/node16": "^16.1.8",
        "@types/node": "^25.5.2",
        "@types/node-schedule": "^2.1.7",
        "@types/suncalc": "^1.9.2",
        "rimraf": "^6.0.1",
        "typescript": "~6.0.2"
    },
    "main": "build/main.js",
    "files": [
        "admin/",
        "build/",
        "io-package.json",
        "LICENSE"
    ],
    "scripts": {
        "prebuild": "rimraf build",
        "build": "npm run build:backend && node tasks",
        "build:backend": "tsc -p tsconfig.build.json",
        "watch": "tsc -p tsconfig.build.json --watch",
        "test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
        "test:package": "mocha test/package --exit",
        "test:integration": "mocha test/integration --exit",
        "test": "npm run test:js && npm run test:package",
        "check": "tsc --noEmit -p tsconfig.json",
        "lint": "eslint -c eslint.config.mjs .",
        "translate": "translate-adapter",
        "release": "release-script",
        "npm": "npm i && cd src-admin && npm i -f",
        "update-packages": "npx -y npm-check-updates --upgrade && cd src-admin && npx -y npm-check-updates --upgrade"
    },
    "bugs": {
        "url": "https://github.com/misanorot/ioBroker.alarm/issues"
    },
    "readmeFilename": "README.md"
}
